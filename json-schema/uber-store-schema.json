{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/Store",
  "title": "Store",
  "type": "object",
  "properties": {
    "store_id": {
      "type": "string",
      "description": "Unique identifier for the store."
    },
    "name": {
      "type": "string",
      "description": "Store display name."
    },
    "status": {
      "type": "string",
      "enum": [
        "online",
        "offline"
      ],
      "description": "Current operational status."
    },
    "address": {
      "type": "object",
      "properties": {
        "street_address": {
          "type": "string"
        },
        "city": {
          "type": "string"
        },
        "state": {
          "type": "string"
        },
        "zip_code": {
          "type": "string"
        },
        "country": {
          "type": "string"
        }
      }
    },
    "contact_emails": {
      "type": "array",
      "items": {
        "type": "string",
        "format": "email"
      }
    }
  }
}