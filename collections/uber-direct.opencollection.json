{
  "opencollection": "1.0.0",
  "info": {
    "name": "Uber Direct API",
    "version": "1.0.0"
  },
  "request": {
    "auth": {
      "type": "bearer",
      "token": "{{bearerToken}}"
    }
  },
  "items": [
    {
      "info": {
        "name": "Deliveries",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Create Delivery",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.uber.com/v1/eats/deliveries",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Create a new delivery request using Uber's courier network."
        },
        {
          "info": {
            "name": "Get Delivery Status",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.uber.com/v1/eats/deliveries/:order_id",
            "params": [
              {
                "name": "order_id",
                "value": "",
                "type": "path",
                "description": "Unique identifier for the delivery order."
              }
            ]
          },
          "docs": "Returns the current status of a delivery order."
        },
        {
          "info": {
            "name": "Cancel Delivery",
            "type": "http"
          },
          "http": {
            "method": "DELETE",
            "url": "https://api.uber.com/v1/eats/deliveries/:order_id",
            "params": [
              {
                "name": "order_id",
                "value": "",
                "type": "path",
                "description": "Unique identifier for the delivery order."
              }
            ]
          },
          "docs": "Cancel an active delivery order."
        },
        {
          "info": {
            "name": "Get Delivery Quote",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.uber.com/v1/eats/deliveries/quote",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Get a price quote for a delivery before creating the order."
        }
      ]
    },
    {
      "info": {
        "name": "Organizations",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "List Organizations",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.uber.com/v1/organizations"
          },
          "docs": "Returns a list of organizations associated with the authenticated account."
        },
        {
          "info": {
            "name": "Get Organization",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.uber.com/v1/organizations/:organization_id",
            "params": [
              {
                "name": "organization_id",
                "value": "",
                "type": "path",
                "description": "Unique identifier for the organization."
              }
            ]
          },
          "docs": "Returns details for a specific organization."
        }
      ]
    },
    {
      "info": {
        "name": "Refunds",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Create Refund",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.uber.com/v1/eats/refunds",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Request a refund for a delivery order."
        }
      ]
    },
    {
      "info": {
        "name": "Locations",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "List Business Locations",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.uber.com/v1/business-locations"
          },
          "docs": "Returns all business locations for the authenticated merchant."
        },
        {
          "info": {
            "name": "Create Business Location",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.uber.com/v1/business-locations",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Create a new business pickup location."
        },
        {
          "info": {
            "name": "Get Business Location",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.uber.com/v1/business-locations/:location_id",
            "params": [
              {
                "name": "location_id",
                "value": "",
                "type": "path",
                "description": "Unique identifier for the business location."
              }
            ]
          },
          "docs": "Returns details for a specific business location."
        },
        {
          "info": {
            "name": "Delete Business Location",
            "type": "http"
          },
          "http": {
            "method": "DELETE",
            "url": "https://api.uber.com/v1/business-locations/:location_id",
            "params": [
              {
                "name": "location_id",
                "value": "",
                "type": "path",
                "description": "Unique identifier for the business location."
              }
            ]
          },
          "docs": "Remove a business pickup location."
        }
      ]
    }
  ],
  "bundled": true
}